  const text = `Hi! I want to place a gift order 🎁\n\nName: ${name}\nPhone: ${phone || 'N/A'}\nOccasion: ${occasion || 'N/A'}\n\nDetails: ${msg}`;
  el.href = 'https://wa.me/918824908236?text=' + encodeURIComponent(text);
  el.target = '_blank';
  return true;
}
</script>
