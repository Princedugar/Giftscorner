<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Giftscorner_2612 — Personalized Gifts</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --gold: #c9a84c;
  --gold-light: #e8c96a;
  --gold-pale: #f5e9c8;
  --dark: #0a0806;
  --dark2: #130f0a;
  --dark3: #1e1610;
  --rose: #e8a0b0;
  --cream: #fdf6ec;
  --text: #f0e6d3;
}

*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}

body {
  background: var(--dark);
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  overflow-x: hidden;
  cursor: none;
}

/* CUSTOM CURSOR */
.cursor {
  width: 10px; height: 10px;
  background: var(--gold);
  border-radius: 50%;
  position: fixed;
  pointer-events: none;
  z-index: 99999;
  transform: translate(-50%,-50%);
  transition: transform 0.1s, width 0.3s, height 0.3s, background 0.3s;
  mix-blend-mode: difference;
}
.cursor-ring {
  width: 36px; height: 36px;
  border: 1px solid rgba(201,168,76,0.6);
  border-radius: 50%;
  position: fixed;
  pointer-events: none;
  z-index: 99998;
  transform: translate(-50%,-50%);
  transition: all 0.15s ease;
}

/* NOISE */
body::after {
  content:'';
  position:fixed;
  inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  pointer-events:none;
  z-index:9998;
  opacity:0.5;
}

/* NAV */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1000;
  padding: 20px 50px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: background 0.4s;
}
nav.scrolled {
  background: rgba(10,8,6,0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(201,168,76,0.1);
}
.nav-logo {
  font-family: 'Playfair Display', serif;
  font-size: 1.25rem;
  color: var(--gold);
  text-decoration: none;
  letter-spacing: 0.04em;
}
.nav-links { display:flex; gap:36px; list-style:none; }
.nav-links a {
  color: rgba(240,230,211,0.65);
  text-decoration: none;
  font-size: 0.78rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--gold); }
.nav-order {
  background: var(--gold);
  color: var(--dark) !important;
  padding: 9px 22px !important;
  opacity: 1 !important;
  font-weight: 600 !important;
  transition: background 0.2s !important;
}
.nav-order:hover { background: var(--gold-light) !important; color: var(--dark) !important; }

/* ===================== HERO ===================== */
.hero {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  padding: 0 50px;
  position: relative;
  overflow: hidden;
  gap: 40px;
}

.hero-bg-glow {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 70% 70% at 70% 40%, rgba(201,168,76,0.09) 0%, transparent 65%),
    radial-gradient(ellipse 40% 40% at 20% 80%, rgba(232,160,176,0.07) 0%, transparent 60%);
  pointer-events: none;
}

.hero-left { position: relative; z-index: 2; padding-top: 80px; }

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border: 1px solid rgba(201,168,76,0.35);
  padding: 7px 16px;
  font-size: 0.68rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 28px;
  opacity: 0;
  animation: slideIn 0.7s 0.2s forwards;
}

.hero-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(3rem, 5.5vw, 5.5rem);
  font-weight: 900;
  line-height: 1.0;
  color: var(--cream);
  opacity: 0;
  animation: slideIn 0.8s 0.4s forwards;
}
.hero-title em {
  display: block;
  font-style: italic;
  font-weight: 400;
  color: var(--gold);
  font-size: 0.6em;
  line-height: 1.4;
}

.hero-sub {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.2rem;
  color: rgba(240,230,211,0.55);
  line-height: 1.8;
  margin: 24px 0 44px;
  max-width: 420px;
  opacity: 0;
  animation: slideIn 0.8s 0.6s forwards;
}

.hero-btns {
  display: flex; gap: 14px; flex-wrap: wrap;
  opacity: 0;
  animation: slideIn 0.8s 0.8s forwards;
}

.btn-wa {
  display: inline-flex; align-items: center; gap: 10px;
  background: #25D366; color: #fff;
  padding: 14px 28px; border-radius: 2px;
  font-size: 0.78rem; font-weight: 600;
  letter-spacing: 0.08em; text-transform: uppercase;
  text-decoration: none;
  transition: all 0.3s;
  box-shadow: 0 4px 20px rgba(37,211,102,0.25);
}
.btn-wa:hover { background: #1dbd5a; transform: translateY(-2px); box-shadow: 0 8px 28px rgba(37,211,102,0.35); }

.btn-ig {
  display: inline-flex; align-items: center; gap: 10px;
  background: linear-gradient(135deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888);
  color: #fff;
  padding: 14px 28px; border-radius: 2px;
  font-size: 0.78rem; font-weight: 600;
  letter-spacing: 0.08em; text-transform: uppercase;
  text-decoration: none;
  transition: all 0.3s;
  box-shadow: 0 4px 20px rgba(220,39,67,0.25);
}
.btn-ig:hover { opacity: 0.9; transform: translateY(-2px); }

.hero-right {
  position: relative;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  animation: fadeIn 1s 0.5s forwards;
}

/* Floating image collage */
.img-collage {
  position: relative;
  width: 100%;
  height: 580px;
}

.img-card {
  position: absolute;
  border-radius: 4px;
  overflow: hidden;
  box-shadow: 0 20px 60px rgba(0,0,0,0.6);
  border: 2px solid rgba(201,168,76,0.15);
  transition: transform 0.4s ease, box-shadow 0.4s;
}
.img-card:hover { transform: scale(1.04) !important; box-shadow: 0 30px 80px rgba(0,0,0,0.7); }

.img-card img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}

.img-card-1 { width: 240px; height: 300px; top: 30px; left: 40px; transform: rotate(-4deg); animation: float1 6s ease-in-out infinite; }
.img-card-2 { width: 200px; height: 250px; top: 10px; right: 20px; transform: rotate(3deg); animation: float2 7s ease-in-out infinite; }
.img-card-3 { width: 220px; height: 280px; bottom: 20px; left: 80px; transform: rotate(2deg); animation: float3 8s ease-in-out infinite; }
.img-card-4 { width: 180px; height: 220px; bottom: 60px; right: 30px; transform: rotate(-3deg); animation: float1 9s ease-in-out infinite; }

.img-label {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: linear-gradient(to top, rgba(10,8,6,0.85), transparent);
  padding: 20px 14px 12px;
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gold);
}

@keyframes float1 {
  0%,100%{ transform: rotate(-4deg) translateY(0); }
  50%{ transform: rotate(-4deg) translateY(-12px); }
}
@keyframes float2 {
  0%,100%{ transform: rotate(3deg) translateY(0); }
  50%{ transform: rotate(3deg) translateY(-16px); }
}
@keyframes float3 {
  0%,100%{ transform: rotate(2deg) translateY(0); }
  50%{ transform: rotate(2deg) translateY(-10px); }
}

.collage-badge {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 90px; height: 90px;
  background: var(--gold);
  border-radius: 50%;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--dark);
  z-index: 10;
  animation: spin-slow 20s linear infinite;
  text-align: center;
  line-height: 1.4;
  padding: 10px;
}

@keyframes spin-slow {
  from { transform: translate(-50%,-50%) rotate(0deg); }
  to { transform: translate(-50%,-50%) rotate(360deg); }
}

@keyframes slideIn {
  from { opacity:0; transform: translateY(30px); }
  to { opacity:1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity:0; } to { opacity:1; }
}

/* TICKER */
.ticker {
  background: var(--gold);
  padding: 11px 0;
  overflow: hidden;
  white-space: nowrap;
}
.ticker-track {
  display: inline-block;
  animation: ticker 30s linear infinite;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--dark);
}
@keyframes ticker {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

/* ===================== GALLERY STRIP ===================== */
.gallery-strip {
  padding: 70px 0;
  overflow: hidden;
  background: var(--dark2);
  border-top: 1px solid rgba(201,168,76,0.08);
  border-bottom: 1px solid rgba(201,168,76,0.08);
}

.gallery-header {
  text-align: center;
  margin-bottom: 50px;
  padding: 0 20px;
}

.section-eyebrow {
  font-size: 0.68rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 12px;
  display: block;
}

.section-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(1.8rem, 3.5vw, 2.8rem);
  font-weight: 700;
  color: var(--cream);
  line-height: 1.15;
}

.section-title em {
  font-style: italic;
  color: var(--gold);
  font-weight: 400;
}

.scroll-gallery {
  display: flex;
  gap: 16px;
  animation: scrollGallery 30s linear infinite;
  width: max-content;
}

.scroll-gallery:hover { animation-play-state: paused; }

.gallery-item {
  width: 260px;
  height: 340px;
  border-radius: 4px;
  overflow: hidden;
  flex-shrink: 0;
  position: relative;
  border: 1px solid rgba(201,168,76,0.12);
  cursor: pointer;
}

.gallery-item img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}

.gallery-item:hover img { transform: scale(1.08); }

.gallery-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(10,8,6,0.8) 0%, transparent 50%);
  opacity: 0;
  transition: opacity 0.3s;
  display: flex;
  align-items: flex-end;
  padding: 20px;
}

.gallery-item:hover .gallery-overlay { opacity: 1; }

.gallery-overlay-text {
  font-size: 0.75rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gold);
}

@keyframes scrollGallery {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

/* ===================== PRODUCTS ===================== */
.products-section {
  padding: 100px 50px;
  max-width: 1200px;
  margin: 0 auto;
}

.products-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 60px;
  flex-wrap: wrap;
  gap: 20px;
}

.view-all-link {
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--gold);
  text-decoration: none;
  border-bottom: 1px solid rgba(201,168,76,0.4);
  padding-bottom: 3px;
  transition: border-color 0.2s;
}
.view-all-link:hover { border-color: var(--gold); }

.products-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
  gap: 24px;
}

.product-card {
  background: var(--dark2);
  border: 1px solid rgba(201,168,76,0.08);
  border-radius: 4px;
  overflow: hidden;
  transition: transform 0.35s, border-color 0.3s, box-shadow 0.35s;
  cursor: pointer;
}

.product-card:hover {
  transform: translateY(-8px);
  border-color: rgba(201,168,76,0.3);
  box-shadow: 0 24px 60px rgba(0,0,0,0.5);
}

.product-img-wrap {
  position: relative;
  aspect-ratio: 4/3;
  overflow: hidden;
}

.product-img-wrap img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}

.product-card:hover .product-img-wrap img { transform: scale(1.08); }

.product-tag {
  position: absolute;
  top: 14px; left: 14px;
  background: var(--gold);
  color: var(--dark);
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 5px 12px;
  border-radius: 1px;
}

.product-tag.new { background: var(--rose); color: #fff; }

.product-img-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(10,8,6,0.5), transparent 60%);
}

.product-info { padding: 24px; }

.product-name {
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
  color: var(--cream);
  margin-bottom: 8px;
}

.product-desc {
  font-size: 0.82rem;
  color: rgba(240,230,211,0.45);
  line-height: 1.65;
  margin-bottom: 20px;
}

.product-cta {
  display: flex;
  align-items: center;
  gap: 12px;
}

.product-order-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: transparent;
  border: 1px solid rgba(201,168,76,0.4);
  color: var(--gold);
  padding: 9px 18px;
  border-radius: 2px;
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  transition: all 0.25s;
  flex: 1;
  justify-content: center;
}

.product-order-btn:hover {
  background: var(--gold);
  color: var(--dark);
  border-color: var(--gold);
}

/* ===================== OCCASIONS ===================== */
.occasions-section {
  padding: 100px 50px;
  background: var(--dark2);
  border-top: 1px solid rgba(201,168,76,0.08);
  border-bottom: 1px solid rgba(201,168,76,0.08);
}

.occasions-inner { max-width: 1200px; margin: 0 auto; }

.occasions-header { margin-bottom: 60px; }

.occasions-masonry {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-template-rows: auto;
  gap: 16px;
}

.occ-card {
  position: relative;
  border-radius: 4px;
  overflow: hidden;
  cursor: pointer;
  border: 1px solid rgba(201,168,76,0.08);
}

.occ-card img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
  display: block;
}

.occ-card:hover img { transform: scale(1.08); }

.occ-card-1 { grid-column: 1/3; height: 280px; }
.occ-card-2 { grid-column: 3/4; height: 280px; }
.occ-card-3 { grid-column: 4/5; height: 280px; }
.occ-card-4 { grid-column: 1/2; height: 240px; }
.occ-card-5 { grid-column: 2/4; height: 240px; }
.occ-card-6 { grid-column: 4/5; height: 240px; }

.occ-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(10,8,6,0.85) 0%, rgba(10,8,6,0.1) 60%, transparent 100%);
  display: flex;
  align-items: flex-end;
  padding: 22px;
  transition: background 0.3s;
}

.occ-card:hover .occ-overlay {
  background: linear-gradient(to top, rgba(10,8,6,0.9) 0%, rgba(10,8,6,0.3) 70%, transparent 100%);
}

.occ-info {}

.occ-emoji { font-size: 1.4rem; display: block; margin-bottom: 6px; }

.occ-name {
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
  color: var(--cream);
  display: block;
  margin-bottom: 4px;
}

.occ-sub {
  font-size: 0.72rem;
  color: var(--gold);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

/* ===================== FEATURES STRIP ===================== */
.features-strip {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border-top: 1px solid rgba(201,168,76,0.1);
  border-bottom: 1px solid rgba(201,168,76,0.1);
}

.feature-item {
  padding: 50px 36px;
  border-right: 1px solid rgba(201,168,76,0.08);
  background: var(--dark3);
  transition: background 0.3s;
  text-align: center;
}

.feature-item:last-child { border-right: none; }
.feature-item:hover { background: rgba(201,168,76,0.04); }

.feat-icon { font-size: 2.2rem; margin-bottom: 18px; display: block; }

.feat-title {
  font-family: 'Playfair Display', serif;
  font-size: 1rem;
  color: var(--cream);
  margin-bottom: 10px;
}

.feat-text { font-size: 0.82rem; color: rgba(240,230,211,0.45); line-height: 1.65; }

/* ===================== HOW IT WORKS ===================== */
.how-section {
  padding: 100px 50px;
  max-width: 1200px;
  margin: 0 auto;
}

.how-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  margin-top: 70px;
}

.how-steps-list { display: flex; flex-direction: column; gap: 36px; }

.how-step {
  display: flex;
  gap: 24px;
  align-items: flex-start;
  padding: 24px;
  background: var(--dark2);
  border: 1px solid rgba(201,168,76,0.08);
  border-radius: 4px;
  transition: border-color 0.3s, background 0.3s;
}

.how-step:hover {
  border-color: rgba(201,168,76,0.3);
  background: rgba(201,168,76,0.03);
}

.step-num {
  font-family: 'Playfair Display', serif;
  font-size: 2rem;
  font-weight: 900;
  color: rgba(201,168,76,0.2);
  line-height: 1;
  min-width: 50px;
}

.step-body {}

.step-title {
  font-family: 'Playfair Display', serif;
  font-size: 1rem;
  color: var(--cream);
  margin-bottom: 6px;
}

.step-text { font-size: 0.82rem; color: rgba(240,230,211,0.45); line-height: 1.65; }

.how-visual {
  position: relative;
  height: 500px;
}

.how-img-main {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 4px;
  border: 1px solid rgba(201,168,76,0.12);
}

.how-img-float {
  position: absolute;
  bottom: -30px;
  left: -30px;
  width: 180px;
  height: 220px;
  object-fit: cover;
  border-radius: 4px;
  border: 2px solid rgba(201,168,76,0.25);
  box-shadow: 0 20px 50px rgba(0,0,0,0.5);
}

.how-quote {
  position: absolute;
  top: 24px; right: -24px;
  background: var(--gold);
  color: var(--dark);
  padding: 16px 20px;
  max-width: 180px;
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: 0.9rem;
  line-height: 1.4;
  box-shadow: 0 10px 30px rgba(0,0,0,0.4);
}

/* ===================== BIG CTA ===================== */
.cta-section {
  padding: 0 50px 100px;
}

.cta-inner {
  max-width: 1200px;
  margin: 0 auto;
  position: relative;
  border-radius: 6px;
  overflow: hidden;
  min-height: 400px;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.cta-bg-img {
  position: absolute;
  inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  filter: brightness(0.25) saturate(1.2);
}

.cta-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(10,8,6,0.7) 0%, rgba(201,168,76,0.08) 50%, rgba(10,8,6,0.7) 100%);
}

.cta-content {
  position: relative;
  z-index: 2;
  padding: 60px 40px;
}

.cta-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 4vw, 3.5rem);
  font-weight: 700;
  color: var(--cream);
  margin-bottom: 16px;
  line-height: 1.15;
}

.cta-sub {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.2rem;
  color: rgba(240,230,211,0.6);
  margin-bottom: 44px;
  max-width: 500px;
  margin-inline: auto;
  line-height: 1.7;
}

.cta-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

/* ===================== CONTACT ===================== */
.contact-section {
  padding: 100px 50px;
  background: var(--dark2);
  border-top: 1px solid rgba(201,168,76,0.08);
}

.contact-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 80px;
  align-items: start;
}

.contact-left {}

.contact-cards { margin-top: 50px; display: flex; flex-direction: column; gap: 16px; }

.contact-card {
